{
  "name": "second-brain",
  "version": "1.0.0",
  "description": "Query engine for your second brain knowledge dump",
  "main": "dist/index.js",
  "type": "module",
  "bin": {
    "brain": "dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "dev:server": "nodemon --watch src --ext ts --exec \"npm run build && node dist/server.js\"",
    "dev:cli": "tsx src/cli.ts",
    "start": "node dist/server.js",
    "cli": "node dist/cli.js",
    "clean": "rm -rf dist"
  },
  "keywords": [
    "knowledge",
    "notes",
    "search",
    "cli"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "chalk": "5.6.2",
    "commander": "14.0.3",
    "koa": "3.1.2",
    "@koa/router": "15.3.1"
  },
  "devDependencies": {
    "@types/koa": "3.0.1",
    "@types/koa-router": "7.4.9",
    "@types/node": "25.3.5",
    "nodemon": "3.1.14",
    "tsx": "4.21.0",
    "typescript": "5.9.3"
  }
}